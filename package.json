{
  "name": "personal-web",
  "version": "0.1.0",
  "private": true,
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:electron": "next build && electron-builder --win",
    "start": "next start",
    "electron:dev": "next build && electron .",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "build": {
    "appId": "com.zhangpanyue.personal-web",
    "productName": "张攀岳个人网站",
    "directories": {
      "output": "dist-electron-new"
    },
    "files": [
      "electron/main.cjs",
      "out/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "dir",
          "arch": ["x64"]
        }
      ],
      "icon": "electron/icon.ico",
      "signtoolOptions": null,
      "signAndEditExecutable": false
    }
  },
  "dependencies": {
    "@gsap/react": "^2.1.2",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@react-three/rapier": "^2.2.0",
    "framer-motion": "^11.18.2",
    "gsap": "^3.15.0",
    "lucide-react": "^0.460.0",
    "meshline": "^3.3.1",
    "next": "^15.1.0",
    "ogl": "^1.0.11",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "jsdom": "^26.0.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.22.4",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
