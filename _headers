# 静态资源长缓存（1年，immutable）
/videos/*
  Cache-Control: public, max-age=31536000, immutable

/audio/*
  Cache-Control: public, max-age=31536000, immutable

/_next/static/*
  Cache-Control: public, max-age=31536000, immutable

# HTML 不缓存，确保用户拿到最新版本
/*.html
  Cache-Control: no-cache, no-store, must-revalidate

# data.json 不缓存，确保数据更新及时
/data.json
  Cache-Control: no-cache, no-store, must-revalidate
